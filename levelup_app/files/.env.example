# LevelUp environment variables
# Copy to .env and fill in values — never commit this file

SECRET_KEY=change_this_to_a_long_random_string

# SQLite database path (inside container, maps to /mnt/storage/levelup.db on host)
DB_PATH=/mnt/storage/levelup.db

# Disk queue path
QUEUE_PATH=/mnt/storage/queue

# File uploads (inside container)
UPLOADS_DIR=/app/uploads

# Ollama (internal Docker network)
OLLAMA_URL=http://ollama:11434

# Admin panel password (visit /admin)
ADMIN_PASSWORD=change_this_too

# NOTE: PocketBase variables are no longer needed.
# POCKETBASE_URL, PB_ADMIN_EMAIL, PB_ADMIN_PASSWORD — all removed.
